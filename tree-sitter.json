{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "iec61131_3",
      "camelcase": "Iec61131_3",
      "scope": "source.iec61131-3",
      "path": ".",
      "file-types": [
        "st",
        "iecst",
        "exp"
      ],
      "highlights": [
        "queries/highlights.scm"
      ],
      "injections": [
        "queries/injections.scm"
      ],
      "locals": [
        "queries/locals.scm"
      ],
      "tags": [
        "queries/tags.scm"
      ]
    }
  ],
  "metadata": {
    "version": "0.0.1",
    "license": "MIT",
    "description": "IEC 61131-3 Structured Text grammar for tree-sitter (standard, dialect-extensible)",
    "authors": [
      {
        "name": "HeytalePazguato",
        "email": "Jecs.09@pm.me"
      }
    ],
    "links": {
      "repository": "https://github.com/HeytalePazguato/tree-sitter-iec61131-3-st"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": false,
    "zig": false
  }
}
