# Build outputs
/dist/
/build/
/out/
/target/

# Local Claude Code settings
.claude/

# The blueprint conventions doc is part of THIS template repo for reference,
# but new projects should not ship it. After "Use this template", run:
#   git rm BLUEPRINT.md && git commit -m "chore: remove template reference"
# This entry then ensures it doesn't get re-added by accident.
/BLUEPRINT.md

# Editor / IDE
.idea/
.vscode/
*.swp

# OS noise
.DS_Store
Thumbs.db

# Secrets
.env
.env.local
*.pem
*.key

# TODO: add language-specific ignores
# Go:    *.exe, *.test, *.out, vendor/
# Node:  node_modules/, npm-debug.log*, yarn-debug.log*, .next/, .nuxt/
# Python: __pycache__/, *.py[cod], .venv/, .pytest_cache/, .ruff_cache/
# Rust:  target/, **/*.rs.bk
